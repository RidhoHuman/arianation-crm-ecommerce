// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS & AUTHENTICATION
// ============================================================

enum UserRole {
  CUSTOMER
  ADMIN
  DESIGN_STAFF
  OWNER
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  password            String
  fullName            String
  phone               String?
  role                UserRole  @default(CUSTOMER)
  isActive            Boolean   @default(true)
  emailVerified       DateTime?
  
  // Relations
  customerProfile     CustomerProfile?
  designStaffInfo     DesignStaffInfo?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([email])
  @@index([role])
}

model CustomerProfile {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  address             String?
  city                String?
  postalCode          String?
  province            String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model DesignStaffInfo {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  specialization      String?
  avgRating           Float     @default(5)
  totalProjects       Int       @default(0)
  isAvailable         Boolean   @default(true)
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ============================================================
// CUSTOMER METRICS & LOYALTY TIER
// ============================================================

enum CustomerTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model CustomerMetrics {
  id                  String    @id @default(cuid())
  userId              String    @unique
  
  // Transaction tracking
  totalTransactions   Int       @default(0)
  totalSpent          Float     @default(0)
  averageOrderValue   Float     @default(0)
  
  // Tier system
  currentTier         CustomerTier @default(BRONZE)
  tierUpgradedAt      DateTime?
  
  // Rating & trust
  averageRating       Float     @default(5)
  cancellationCount   Int       @default(0)
  returnCount         Int       @default(0)
  
  // COD eligibility
  isCODEligible       Boolean   @default(false)
  codAutoApproval     Boolean   @default(false)
  
  // Loyalty points
  loyaltyPoints       Int       @default(0)
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ============================================================
// PRODUCTS & CATEGORIES
// ============================================================

enum BusinessType {
  FASHION_RETAIL
  SABLON_SERVICE
}

enum ProductType {
  KAOS
  ATRIBUT
  SABLON_TEMPLATE
}

model ProductCategory {
  id                  String    @id @default(cuid())
  categoryName        String    @unique
  businessType        BusinessType
  description         String?
  iconUrl             String?
  
  products            Product[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([businessType])
}

model Product {
  id                  String    @id @default(cuid())
  categoryId          String
  category            ProductCategory @relation(fields: [categoryId], references: [id])
  
  productName         String
  description         String?
  price               Float
  stockQuantity       Int       @default(0)
  productType         ProductType
  imageUrl            String?
  businessType        BusinessType
  isActive            Boolean   @default(true)
  
  variants            ProductVariant[]
  cartItems           CartItem[]
  orderItems          OrderItem[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([categoryId])
  @@index([businessType])
}

model ProductVariant {
  id                  String    @id @default(cuid())
  productId           String
  product             Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  variantName         String    // SIZE, COLOR
  sku                 String    @unique
  additionalPrice     Float     @default(0)
  stockQuantity       Int       @default(0)
  
  cartItems           CartItem[]
  orderItems          OrderItem[]
  
  createdAt           DateTime  @default(now())

  @@index([productId])
}

// ============================================================
// SHOPPING CART
// ============================================================

model ShoppingCart {
  id                  String    @id @default(cuid())
  userId              String    @unique
  
  items               CartItem[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model CartItem {
  id                  String    @id @default(cuid())
  cartId              String
  cart                ShoppingCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  
  productId           String
  product             Product   @relation(fields: [productId], references: [id])
  
  variantId           String?
  variant             ProductVariant? @relation(fields: [variantId], references: [id])
  
  quantity            Int
  unitPrice           Float
  subtotal            Float
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([cartId])
  @@index([productId])
}

// ============================================================
// ORDERS
// ============================================================

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  READY_FOR_DELIVERY
  SHIPPED
  DELIVERED
  CANCELLED
  FAILED
}

enum PaymentMethod {
  QRIS
  BANK_TRANSFER
  COD
}

model Order {
  id                  String    @id @default(cuid())
  orderNumber         String    @unique @default(cuid())
  
  userId              String
  
  orderDate           DateTime  @default(now())
  totalAmount         Float
  status              OrderStatus @default(PENDING)
  paymentMethod       PaymentMethod
  
  deliveryAddress     String?
  deliveryDate        DateTime?
  notes               String?
  
  items               OrderItem[]
  payment             Payment?
  tracking            OrderTracking?
  designRequests      DesignRequest[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([orderDate])
}

model OrderItem {
  id                  String    @id @default(cuid())
  orderId             String
  order               Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId           String
  product             Product   @relation(fields: [productId], references: [id])
  
  variantId           String?
  variant             ProductVariant? @relation(fields: [variantId], references: [id])
  
  designRequestId     String?
  designRequest       DesignRequest? @relation(fields: [designRequestId], references: [id])
  
  quantity            Int
  unitPrice           Float
  subtotal            Float
  notes               String?
  
  createdAt           DateTime  @default(now())

  @@index([orderId])
  @@index([productId])
}

// ============================================================
// PAYMENTS
// ============================================================

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

model Payment {
  id                  String    @id @default(cuid())
  orderId             String    @unique
  order               Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  paymentDate         DateTime?
  amount              Float
  method              PaymentMethod
  status              PaymentStatus @default(PENDING)
  
  transactionId       String    @unique
  xenditId            String?   @unique
  
  // QRIS specific
  qrisReference       String?
  qrisUrl             String?
  
  // Bank transfer specific
  bankAccount         String?
  bankName            String?
  accountName         String?
  
  receiptUrl          String?
  
  // Verification
  verifiedBy          String?
  verifiedAt          DateTime?
  notes               String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([transactionId])
}

// ============================================================
// CUSTOM DESIGN / SABLON
// ============================================================

enum DesignStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  APPROVED
  REJECTED
  IN_PRODUCTION
  COMPLETED
}

model DesignRequest {
  id                  String    @id @default(cuid())
  orderId             String?
  order               Order?    @relation(fields: [orderId], references: [id])
  
  userId              String
  
  designTitle         String
  designDescription   String?
  referenceImageUrl   String?
  designFileUrl       String
  fileType            String    // PNG, JPG, PDF, AI, CDR
  
  quantity            Int
  productTypeForSablon String?
  colorPreferences    String?
  
  status              DesignStatus @default(DRAFT)
  submittedAt         DateTime?
  deadline            DateTime?
  
  feedback            DesignFeedback[]
  orderItems          OrderItem[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

model DesignFeedback {
  id                  String    @id @default(cuid())
  designRequestId     String
  designRequest       DesignRequest @relation(fields: [designRequestId], references: [id], onDelete: Cascade)
  
  designStaffId       String
  
  feedbackText        String
  feedbackType        String    // APPROVED, REVISION_NEEDED, REJECTED
  revisionNotes       String?
  suggestedChangesUrl String?
  
  createdAt           DateTime  @default(now())

  @@index([designRequestId])
}

// ============================================================
// ORDER TRACKING
// ============================================================

enum TrackingStatus {
  PROCESSING
  PACKED
  SHIPPED
  IN_DELIVERY
  DELIVERED
}

model OrderTracking {
  id                  String    @id @default(cuid())
  orderId             String    @unique
  order               Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  status              TrackingStatus @default(PROCESSING)
  currentLocation     String?
  estimatedDeliveryDate DateTime?
  
  carrier             String?
  trackingNumber      String?
  lastUpdate          DateTime?
  notes               String?
  
  history             TrackingHistory[]
  
  updatedAt           DateTime  @updatedAt

  @@index([orderId])
}

model TrackingHistory {
  id                  String    @id @default(cuid())
  trackingId          String
  tracking            OrderTracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  
  status              TrackingStatus
  location            String?
  timestamp           DateTime  @default(now())
  notes               String?

  @@index([trackingId])
}

// ============================================================
// LOYALTY PROGRAM
// ============================================================

enum LoyaltyTransactionType {
  EARNED
  REDEEMED
  ADJUSTED
}

enum LoyaltyRedemptionStatus {
  COMPLETED
  EXPIRED
  CANCELLED
}

model LoyaltyTransaction {
  id                  String    @id @default(cuid())
  userId              String
  
  orderId             String?
  
  transactionType     LoyaltyTransactionType
  pointsAmount        Int
  reason              String?
  
  balanceBefore       Int
  balanceAfter        Int
  
  createdAt           DateTime  @default(now())

  @@index([userId])
}

model LoyaltyRedemption {
  id                  String    @id @default(cuid())
  userId              String
  
  discountAmount      Float
  pointsUsed          Int
  
  orderId             String?
  
  redemptionDate      DateTime  @default(now())
  status              LoyaltyRedemptionStatus @default(COMPLETED)

  @@index([userId])
}

// ============================================================
// NOTIFICATIONS
// ============================================================

enum NotificationType {
  ORDER_CONFIRMED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  DESIGN_FEEDBACK
  DESIGN_APPROVED
  ORDER_READY
  DELIVERY_UPDATE
  PROMOTION
  LOYALTY_POINTS_EARNED
  TIER_UPGRADED
}

model Notification {
  id                  String    @id @default(cuid())
  userId              String
  
  notificationType    NotificationType
  title               String
  message             String
  
  relatedOrderId      String?
  relatedDesignId     String?
  
  isRead              Boolean   @default(false)
  readAt              DateTime?
  
  createdAt           DateTime  @default(now())

  @@index([userId])
  @@index([isRead])
}

// ============================================================
// ANALYTICS & REPORTS
// ============================================================

model SalesAnalytics {
  id                  String    @id @default(cuid())
  date                DateTime  @unique
  
  totalOrders         Int
  totalRevenue        Float
  totalCustomers      Int
  averageOrderValue   Float
  
  businessTypeBreakdown String? // JSON: {fashion: X, sablon: Y}
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([date])
}

model ProductPerformance {
  id                  String    @id @default(cuid())
  productId           String
  
  period              String    // MONTHLY or YEARLY
  
  totalSold           Int
  totalRevenue        Float
  ratingAverage       Float
  trend               String    // UP, DOWN, STABLE
  
  createdAt           DateTime  @default(now())

  @@index([productId])
}

model AdminActivityLog {
  id                  String    @id @default(cuid())
  adminId             String
  
  action              String    // PAYMENT_VERIFIED, ORDER_CANCELLED, etc
  targetId            String?   // Order ID, Payment ID, etc
  targetType          String?   // Order, Payment, etc
  details             String?   // JSON details
  
  createdAt           DateTime  @default(now())

  @@index([adminId])
  @@index([createdAt])
}