# Database
DATABASE_URL="postgresql://arianation_user:password@localhost:5432/arianation_db?schema=public"

# JWT
JWT_SECRET="your_jwt_secret_key_here"
JWT_EXPIRE="7d"

# Server
PORT=3001
NODE_ENV=development
BASE_URL="http://localhost:3001"

# Frontend
FRONTEND_URL="http://localhost:3000"

# Xendit
XENDIT_API_KEY="your_xendit_api_key_here"
XENDIT_WEBHOOK_VERIFY_TOKEN="your_webhook_token_here"

# Bank Transfer
BANK_ACCOUNT_NUMBER="your_bank_account_number"
BANK_NAME="your_bank_name"
BANK_ACCOUNT_NAME="your_account_name"